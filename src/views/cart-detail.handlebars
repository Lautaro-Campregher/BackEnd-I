{{>navbar}}

<h1>Mi Carrito</h1>

{{#if cart.products.length}}

<ul>

{{#each cart.products}}

<li>
    <img src="/img/products/{{product.thumbnails.[0]}}" 
    alt="{{product.name}}"
    width="200"
    >

<p>{{this.product.name}}</p>
<p>${{this.product.price}}</p>
<p>Cantidad: {{this.quantity}}</p>
<p>Subtotal:${{this.subtotal}}</p>

<button 
class="delete-product" 
data-product-id ="{{this.product._id}}"
>
Eliminar
</button>


</li>

{{/each}}

<h2>Total : ${{total}}</h2>

</ul>

{{else}}

<p>El carrito está vacío</p>


{{/if}}
<script src="/js/cart-detail.js"></script>

