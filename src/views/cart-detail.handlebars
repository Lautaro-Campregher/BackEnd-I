<link rel="stylesheet" href="/css/cart-detail.css">
{{>navbar}}

<h1>Mi Carrito</h1>

{{#if cart.products.length}}

<ul>

{{#each cart.products}}

<li>
    <img src="/img/products/{{product.thumbnails.[0]}}" 
    alt="{{product.title}}"
    width="200"
    >

<p>{{this.product.title}}</p>
<p>${{this.product.price}}</p>
<p>Cantidad: {{this.quantity}}</p>
<p>Subtotal:${{this.subtotal}}</p>

<button 
class="delete-product" 
data-product-id ="{{this.product._id}}"
>
Eliminar
</button>


</li>

{{/each}}

<h2>Total : ${{total}}</h2>

<button id="clearCart">
  Vaciar carrito
</button>

</ul>

{{else}}

<p class="empty-cart">El carrito está vacío.</p>


{{/if}}
<script src="/js/cart-detail.js"></script>

