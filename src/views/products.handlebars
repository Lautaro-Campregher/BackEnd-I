<link rel="stylesheet" href="/css/products.css">
{{>navbar}}

<h1>{{message}}</h1>

<div id="products-container">

{{#each products}}

<ul>
  <li>
    <p>{{this.name}}</p>
    <p>{{this.price}}</p>
    <p>{{this.description}}</p>
    <p>{{this.stock}}</p>

    <img
      src="/img/products/{{this.thumbnails.[0]}}"
      alt="{{this.name}}"
      width="200"
    >

    <a href="/products/{{this._id}}">Ver detalle</a>
  </li>
</ul>

{{/each}}

</div>

<script src="/socket.io/socket.io.js"></script>
<script src="/js/realtime-products.js"></script>