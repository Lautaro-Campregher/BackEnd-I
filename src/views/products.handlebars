<link rel="stylesheet" href="/css/products.css">
{{>navbar}}
<h1>{{message}}</h1>

{{#each products}}
 
    <ul>
      <li>
        <p>{{this.name}}</p>
        <p>{{this.price}}</p>
        <p>{{this.description}}</p>
        <p>{{this.stock}}</p>
        <img src="/img/products/{{this.thumbnails.[0]}}" alt="{{this.name}}" width="200">
      </li>
    </ul>
  

{{/each}}