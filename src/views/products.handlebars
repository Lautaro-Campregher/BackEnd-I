<link rel="stylesheet" href="/css/products.css">
{{>navbar}}
<h1>{{message}}</h1>

{{#each products}}
  {{#if (isStock this.stock 2)}}
    <ul>
      <li>
        <p>{{this.name}}</p>
        <p>{{this.price}}</p>
        <p>{{this.description}}</p>
        <p>{{this.stock}}</p>
      </li>
    </ul>
  {{/if}}

{{/each}}